{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "moduleResolution": "nodenext",

    "typeRoots": ["./node_modules/@types", "./src/types"]
  },

  "include": ["src"]
}
